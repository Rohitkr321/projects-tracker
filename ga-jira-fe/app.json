{
  "expo": {
    "name": "General Aeronautics",
    "slug": "ga-issuestracker",
    "owner": "kabeerdev",
    "version": "1.0.0",
    "orientation": "portrait",
    "updates": {
      "enabled": false
    },
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ga-logo-full.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0F2557"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.kabeerdev.gaissuestracker",
      "adaptiveIcon": {
        "backgroundColor": "#0F2557",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "General Aeronautics",
      "shortName": "GA Tracker",
      "description": "General Aeronautics internal task tracker"
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "47205c29-3318-4018-b5e0-b542412339f3"
      }
    }
  }
}
